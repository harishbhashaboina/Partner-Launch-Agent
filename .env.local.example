# Copy this file to `.env.local` and fill in the values, then restart `npm run dev`.
# This codebase uses the OpenAI SDK, which can talk to ANY OpenAI-compatible API
# by overriding OPENAI_BASE_URL. Pick one provider below.

# ───────────────────────────────────────────────────────────────
# Option A — OpenAI (paid; requires billing balance at https://platform.openai.com/account/billing)
# ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# (leave OPENAI_BASE_URL unset to use OpenAI default)

# ───────────────────────────────────────────────────────────────
# Option B — Groq (FREE, fast, OpenAI-compatible) — recommended free choice
# Sign up: https://console.groq.com → "API Keys" → Create key
# ───────────────────────────────────────────────────────────────
# OPENAI_API_KEY=gsk_your_groq_key_here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# (other free Groq models: llama-3.1-8b-instant, gpt-oss-120b)

# ───────────────────────────────────────────────────────────────
# Option C — OpenRouter (free models available)
# Sign up: https://openrouter.ai → Keys
# ───────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-or-v1-your_openrouter_key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ───────────────────────────────────────────────────────────────
# Option D — Google Gemini (free tier; OpenAI-compatible endpoint)
# Sign up: https://aistudio.google.com → "Get API key"
# ───────────────────────────────────────────────────────────────
# OPENAI_API_KEY=AIza_your_gemini_key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.5-flash

# ───────────────────────────────────────────────────────────────
# Option E — Local Ollama (free, no key, runs on your Mac)
# Install: brew install ollama && ollama pull llama3.1
# Start: `ollama serve` (or it auto-starts via the app)
# ───────────────────────────────────────────────────────────────
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1

# ───────────────────────────────────────────────────────────────
# Optional: override partner brief folder.
# Defaults to /Users/saikumarguntoju/PartnerTemplatesFilled
# ───────────────────────────────────────────────────────────────
# PARTNER_TEMPLATES_DIR=/Users/saikumarguntoju/PartnerTemplatesFilled
